# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tutu_vision?schema=public"

# JWT
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# Server
PORT=3000

# Image Generation
IMAGE_PROVIDER="openai"
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_IMAGE_MODEL="gpt-image-1"

# Asset serving
PUBLIC_ASSET_BASE_URL="http://127.0.0.1:3000/static"

# Admin panel
ADMIN_COOKIE_SECRET="change-me-to-a-random-secret"
ADMIN_EMAIL="admin@tutu.local"
ADMIN_PASSWORD="your-admin-password"
ADMIN_OPERATOR_EMAIL="operator@tutu.local"
ADMIN_OPERATOR_PASSWORD="your-operator-password"
